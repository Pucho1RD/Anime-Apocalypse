local function enableFly(char)
   local hrp = char:FindFirstChild("HumanoidRootPart")
   if not hrp then return end

   if not hrp:FindFirstChild("FlyForce") then
      local bp = Instance.new("BodyPosition")
      bp.Name = "FlyForce"
      bp.MaxForce = Vector3.new(1e5, 1e5, 1e5)
      bp.P = 5000
      bp.D = 1000
      bp.Position = hrp.Position
      bp.Parent = hrp
   end
end

local function disableFly(char)
   local hrp = char:FindFirstChild("HumanoidRootPart")
   if hrp and hrp:FindFirstChild("FlyForce") then
      hrp.FlyForce:Destroy()
   end
end

_G.CurrentTarget = nil

local function isPriority(name)
   for _,p in ipairs(_G.PriorityList) do
      if string.find(string.lower(name), string.lower(p)) then
         return true
      end
   end
   return false
end


_G.PriorityList = {
   "King of Curses",
   "Samurai",
   "Lava Admiral",
   "Upper Moon 3",
   "Marine"
}

local function getTarget()
   local zombies = workspace:FindFirstChild("Zombies")
   if not zombies then return nil end

   local char = player.Character
   if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

   local myPos = char.HumanoidRootPart.Position

   local best = nil
   local bestDist = math.huge
   local priorityTarget = nil
   local priorityDist = math.huge

   for _,z in pairs(zombies:GetChildren()) do
      local hrp = z:FindFirstChild("HumanoidRootPart")

      if hrp then
         local dist = (hrp.Position - myPos).Magnitude

         if isPriority(z.Name) then
            if dist < priorityDist then
               priorityDist = dist
               priorityTarget = z
            end
         end

         if dist < bestDist then
            bestDist = dist
            best = z
         end
      end
   end

   return priorityTarget or best
end

local function setupFloat(char)
   local hrp = char:FindFirstChild("HumanoidRootPart")
   if not hrp then return end

   -- quitar viejos
   if hrp:FindFirstChild("AlignPosition") then return end

   local att0 = Instance.new("Attachment", hrp)
   att0.Name = "TP_Attachment"

   local align = Instance.new("AlignPosition")
   align.Name = "AlignPosition"
   align.Attachment0 = att0
   align.MaxForce = 1e6
   align.Responsiveness = 50
   align.RigidityEnabled = true
   align.Parent = hrp

   local alignRot = Instance.new("AlignOrientation")
   alignRot.Attachment0 = att0
   alignRot.MaxTorque = 1e6
   alignRot.Responsiveness = 50
   alignRot.Parent = hrp
end

local function clearFloat(char)
   local hrp = char:FindFirstChild("HumanoidRootPart")
   if not hrp then return end

   for _,v in pairs(hrp:GetChildren()) do
      if v.Name == "AlignPosition" or v.Name == "AlignOrientation" or v.Name == "TP_Attachment" then
         v:Destroy()
      end
   end
end

