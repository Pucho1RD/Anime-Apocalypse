local Utils = require(game:GetService("ReplicatedStorage").Assets.Modules.Utils)

local function getEquippedForm()
    local slots = player:WaitForChild("Data"):WaitForChild("AbilitySlots")

    local decoded = Utils.Decode(slots.Value)

    for slot, info in pairs(decoded) do
        if info and info.Showcasing then
            return info.Name
        end
    end

    return nil
end


task.spawn(function()
    while true do
